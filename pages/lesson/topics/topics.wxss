.page { padding: 24rpx; }
.card { margin-bottom: 16rpx; }

.head { padding: 28rpx; }
.head .emoji { font-size: 48rpx; }
.head .big { font-size: 32rpx; font-weight: 700; color: #333; line-height: 1; }
.head .sm { font-size: 20rpx; color: #888; margin-top: 4rpx; }

.section-t {
  font-size: 22rpx; color: #999; font-weight: 500;
  margin: 24rpx 8rpx 12rpx; padding-left: 8rpx;
}

.recommend {
  padding: 24rpx; background: linear-gradient(135deg, #FFFBEB, #FEF3C7);
}

.topic-item { padding: 24rpx; }

.topic-icon {
  width: 80rpx; height: 80rpx; border-radius: 20rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 40rpx;
}
.topic-icon.small { width: 64rpx; height: 64rpx; font-size: 32rpx; border-radius: 16rpx; }

.t-name { font-size: 28rpx; font-weight: 700; color: #333; }
.t-meta { font-size: 22rpx; color: #888; margin-top: 6rpx; }
.t-meta-sm { font-size: 20rpx; color: #999; margin-top: 4rpx; }

.go-btn {
  background: #F59E0B; color: #fff;
  border-radius: 999rpx; padding: 12rpx 28rpx;
  font-size: 24rpx; font-weight: 600;
}

.locked { font-size: 32rpx; color: #ccc; }

.prog-mini {
  width: 80rpx; height: 12rpx; background: #F0EBE0;
  border-radius: 999rpx; overflow: hidden;
}
.prog-fill-mini {
  height: 100%; background: linear-gradient(90deg, #FCD34D, #F59E0B);
}
