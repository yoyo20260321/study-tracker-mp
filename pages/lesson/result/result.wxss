.page {
  min-height: 100vh; padding: 140rpx 40rpx 60rpx;
  display: flex; flex-direction: column;
  box-sizing: border-box;
}
.page.perfect { background: linear-gradient(180deg, #FFFBEB, #FEF3C7); }
.page.normal  { background: linear-gradient(180deg, #FAF7F2, #fff); }

.hero { text-align: center; padding: 48rpx 0; }
.title {
  font-size: 48rpx; font-weight: 800; color: #B45309;
  margin-top: 24rpx;
}
.subtitle { font-size: 26rpx; color: #888; margin-top: 12rpx; }

.rewards {
  display: flex; flex-wrap: wrap; gap: 16rpx;
  margin: 32rpx 0;
}
.reward-card {
  flex: 1 1 calc(50% - 8rpx); min-width: 200rpx;
  background: #fff; border-radius: 20rpx; padding: 24rpx;
  text-align: center; box-shadow: 0 4rpx 16rpx rgba(180,135,30,.08);
}
.rw-num { font-size: 44rpx; font-weight: 700; line-height: 1; }
.rw-num.xp     { color: #F59E0B; }
.rw-num.streak { color: #fb7185; }
.rw-num.bonus  { color: #B45309; }
.rw-lbl { font-size: 22rpx; color: #666; margin-top: 8rpx; }

.bottom { margin-top: auto; display: flex; flex-direction: column; gap: 16rpx; }

.btn-primary-big {
  background: linear-gradient(135deg, #FCD34D, #F59E0B); color: #fff;
  border: none; padding: 32rpx; border-radius: 24rpx;
  font-size: 34rpx; font-weight: 700;
  box-shadow: 0 8rpx 24rpx rgba(245, 158, 11, .3);
}
.btn-secondary {
  background: #fff; color: #666;
  border: 2rpx solid #E5E5E5;
  padding: 24rpx; border-radius: 20rpx;
  font-size: 28rpx;
}
.btn-share {
  background: #07C160; color: #fff; border: none;
  padding: 24rpx; border-radius: 20rpx;
  font-size: 28rpx; font-weight: 500;
}
