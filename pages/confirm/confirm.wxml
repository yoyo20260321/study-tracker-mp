<view class="page">
  <view class="card preview-card">
    <image src="{{path}}" class="preview" mode="aspectFit"/>
  </view>

  <view class="card info">
    <view class="row" style="justify-content: space-between;">
      <view>
        <view class="muted">学段</view>
        <view class="val">{{grade}}</view>
      </view>
      <view>
        <view class="muted">科目</view>
        <view class="val">{{subject}}</view>
      </view>
      <view>
        <view class="muted">消耗</view>
        <view class="val txt-honey">🎫 1 次</view>
      </view>
    </view>
  </view>

  <button class="btn-primary" style="width: 100%; margin-top: 32rpx;" bindtap="submit" disabled="{{loading}}">
    {{loading ? '上传中...' : '✨ 开始诊断'}}
  </button>
  <button class="btn-ghost" style="width: 100%; margin-top: 16rpx;" bindtap="back">🔄 重拍</button>
</view>
