.page { padding: 24rpx; background: #FFFBEB; min-height: 100vh; }
.empty { text-align: center; padding: 80rpx; color: #999; font-size: 28rpx; }
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 80rpx 40rpx; }
.empty-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.empty-msg { font-size: 30rpx; color: #B45309; font-weight: 600; margin-bottom: 16rpx; text-align: center; }
.empty-hint { font-size: 26rpx; color: #999; text-align: center; }

.me-card { background: #FEF3C7; border-radius: 20rpx; padding: 28rpx 32rpx; margin-bottom: 24rpx; display: flex; align-items: center; gap: 16rpx; }
.me-label { font-size: 26rpx; color: #92400E; }
.me-rank { font-size: 40rpx; font-weight: 700; color: #B45309; flex: 1; }
.me-xp { font-size: 28rpx; color: #D97706; }

.list-header { font-size: 26rpx; color: #92400E; margin-bottom: 16rpx; padding: 0 4rpx; }
.row-item { display: flex; align-items: center; gap: 12rpx; background: #fff; border-radius: 14rpx; padding: 20rpx 24rpx; margin-bottom: 12rpx; font-size: 26rpx; }
.highlight { background: #FEF3C7; border: 2rpx solid #F59E0B; }
.rank-num { width: 60rpx; text-align: center; font-weight: 700; color: #B45309; font-size: 28rpx; }
.flex-1 { flex: 1; }
.phone { color: #333; }
.lv { color: #7C3AED; font-size: 24rpx; }
.streak { color: #EF4444; font-size: 24rpx; }
.xp { color: #D97706; font-size: 24rpx; font-weight: 600; }
