.page { padding: 24rpx; }
.head { text-align: center; padding: 32rpx 0; }
.t { font-size: 32rpx; font-weight: 700; color: #B45309; }
.s { font-size: 22rpx; color: #888; margin-top: 8rpx; }

.plan {
  border: 4rpx solid #F0EBE0; border-radius: 24rpx;
  padding: 28rpx; margin-bottom: 16rpx;
  position: relative; background: #fff;
}
.plan.rec {
  border-color: #F59E0B;
  background: linear-gradient(135deg, #FFFBEB, #FEF3C7);
}
.badge {
  position: absolute; top: -16rpx; right: 24rpx;
  background: #fb7185; color: #fff; font-size: 18rpx;
  padding: 4rpx 16rpx; border-radius: 999rpx; font-weight: 600;
}
.icon {
  width: 96rpx; height: 96rpx; border-radius: 16rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 48rpx; color: #fff; flex-shrink: 0;
}
.p-name { font-size: 28rpx; font-weight: 600; color: #333; }
.p-desc { font-size: 22rpx; color: #888; margin-top: 6rpx; line-height: 1.5; }
.p-old { font-size: 22rpx; color: #aaa; text-decoration: line-through; }
.p-price { font-size: 40rpx; font-weight: 700; color: #B45309; }
.plan.rec .p-price { color: #fb7185; }

.legal {
  font-size: 20rpx; color: #aaa; text-align: center;
  line-height: 1.8; padding: 24rpx; white-space: pre-line;
}
