.page { padding: 48rpx 32rpx 96rpx; }
.hero { text-align: center; padding: 32rpx 0 48rpx; }
.title { font-size: 44rpx; font-weight: 700; color: #B45309; margin-top: 24rpx; }
.subtitle { font-size: 24rpx; color: #888; margin-top: 12rpx; }
.form { padding: 32rpx; }
.tip {
  background: #FEF3C7; color: #B45309; font-size: 22rpx;
  border-radius: 16rpx; padding: 16rpx 20rpx; margin-bottom: 32rpx; line-height: 1.6;
}
.tip .code { font-family: monospace; font-weight: 700; font-size: 26rpx; }
.field { margin-bottom: 24rpx; }
.label { font-size: 22rpx; color: #888; margin-bottom: 12rpx; }
.input {
  background: #FAF7F2; border-radius: 12rpx;
  padding: 20rpx 24rpx; font-size: 28rpx;
}
.btn-code {
  background: #7A8C70; color: #fff; font-size: 24rpx;
  border-radius: 12rpx; padding: 0 24rpx; height: 76rpx;
  line-height: 76rpx; min-width: 180rpx;
}
.btn-code[disabled] { background: #ccc; }
.legal { font-size: 20rpx; color: #aaa; text-align: center; margin-top: 24rpx; line-height: 1.8; }
.error {
  background: #FEE2E2; color: #B91C1C; font-size: 24rpx;
  padding: 16rpx 20rpx; border-radius: 12rpx; margin-top: 24rpx;
}
