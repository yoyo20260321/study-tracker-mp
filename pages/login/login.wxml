<view class="page">
  <view class="hero">
    <view class="bee-bob" style="font-size: 100rpx;">🐝</view>
    <view class="title">欢迎来到蜂学</view>
    <view class="subtitle">手机号一键登录, 同号同账号同历史</view>
  </view>

  <view class="card form">
    <view class="tip">📌 V0.6 内测期, 验证码统一为 <text class="code">000000</text></view>

    <view class="field">
      <view class="label">手机号</view>
      <input class="input" type="number" maxlength="11" placeholder="11 位中国大陆手机号" value="{{phone}}" bindinput="onPhoneInput"/>
    </view>

    <view class="field">
      <view class="label">验证码</view>
      <view class="row" style="gap: 16rpx;">
        <input class="input flex-1" type="number" maxlength="6" placeholder="6 位验证码" value="{{code}}" bindinput="onCodeInput"/>
        <button class="btn-code" bindtap="onSendCode" disabled="{{codeCountdown > 0}}">
          {{codeCountdown > 0 ? codeCountdown + 's' : '发送验证码'}}
        </button>
      </view>
    </view>

    <button class="btn-primary" style="width: 100%; margin-top: 32rpx;" bindtap="onLogin" disabled="{{loading}}">
      {{loading ? '登录中...' : '登录 / 注册'}}
    </button>

    <view class="legal">首次登录自动注册 · 登录态保留 7 天</view>

    <view class="error" wx:if="{{error}}">{{error}}</view>
  </view>
</view>
