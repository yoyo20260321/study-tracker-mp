<view class="page">

  <!-- 顶部进度条 -->
  <view class="topbar" wx:if="{{step > 0}}">
    <view class="back" bindtap="prevStep">‹</view>
    <view class="progress">
      <view class="progress-fill" style="width: {{step * 33}}%;"></view>
    </view>
  </view>

  <!-- Step 0: 介绍 -->
  <view wx:if="{{step === 0}}" class="screen">
    <view class="mascot-wrap">
      <view class="bee-bob mascot">🐝</view>
      <view class="bubble">嗨, 我是蜂学老师!<view class="br"></view>让我帮你搞定数学这件事 ~</view>
    </view>

    <view class="sells">
      <view class="sell-row">
        <view class="sell-icon" style="background: #FEF3C7;">📸</view>
        <view class="sell-text">
          <view class="sell-t">拍卷秒诊断</view>
          <view class="sell-s">一张试卷照片, 30 秒出诊断报告 + 弱点定位</view>
        </view>
      </view>
      <view class="sell-row">
        <view class="sell-icon" style="background: #DDE5D6;">🎯</view>
        <view class="sell-text">
          <view class="sell-t">知道哪里该补</view>
          <view class="sell-s">AI 告诉你这周重点攻克哪几道题, 不再瞎刷</view>
        </view>
      </view>
      <view class="sell-row">
        <view class="sell-icon" style="background: #FFE4E6;">🎮</view>
        <view class="sell-text">
          <view class="sell-t">升级打怪不无聊</view>
          <view class="sell-s">攒经验值, 解锁等级, 跟自己比进步</view>
        </view>
      </view>
    </view>

    <view class="bottom-cta">
      <button class="btn-continue" bindtap="nextStep">继续</button>
    </view>
  </view>

  <!-- Step 1: 年级 -->
  <view wx:if="{{step === 1}}" class="screen">
    <view class="mascot-wrap">
      <view class="bee-bob mascot small">🐝</view>
      <view class="bubble">你上几年级了?</view>
    </view>

    <view class="choices">
      <view wx:for="{{grades}}" wx:key="value"
            class="choice {{form.grade === item.value ? 'selected' : ''}}"
            bindtap="pickGrade" data-v="{{item.value}}">
        <view class="badge" style="background: {{item.color}};">{{item.num}}</view>
        <view class="choice-text">{{item.value}}</view>
      </view>
    </view>

    <view class="bottom-cta">
      <button class="btn-continue" bindtap="nextStep" disabled="{{!form.grade}}">继续</button>
    </view>
  </view>

  <!-- Step 2: 城市 -->
  <view wx:if="{{step === 2}}" class="screen">
    <view class="mascot-wrap">
      <view class="bee-bob mascot small">🐝</view>
      <view class="bubble">你在哪个城市?</view>
    </view>

    <scroll-view scroll-y class="choices scroll-list" enhanced show-scrollbar="{{false}}">
      <view wx:for="{{cities}}" wx:key="value"
            class="choice {{form.city === item.value ? 'selected' : ''}}"
            bindtap="pickCity" data-v="{{item.value}}">
        <view class="badge" style="background: {{item.color}};">{{item.emoji}}</view>
        <view class="choice-text">{{item.value}}</view>
      </view>
    </scroll-view>

    <view class="bottom-cta">
      <button class="btn-continue" bindtap="nextStep" disabled="{{!form.city}}">继续</button>
    </view>
  </view>

  <!-- Step 3: 学校 -->
  <view wx:if="{{step === 3}}" class="screen">
    <view class="mascot-wrap">
      <view class="bee-bob mascot small">🐝</view>
      <view class="bubble">最后一步, 你在哪个学校上学?</view>
    </view>

    <view class="school-section">
      <input class="school-input" placeholder="如: 杭州外国语学校" value="{{form.school}}" bindinput="onSchool" maxlength="40" focus="{{true}}"/>
      <view class="school-hint">不填也可以, 之后能在「我的」补</view>
    </view>

    <view class="bottom-cta">
      <button class="btn-continue" bindtap="finish" disabled="{{saving}}">
        {{saving ? '保存中...' : (form.school ? '完成' : '跳过, 直接开始')}}
      </button>
      <view class="error" wx:if="{{error}}">{{error}}</view>
    </view>
  </view>
</view>
