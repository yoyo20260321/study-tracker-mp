.page { padding: 24rpx; background: #FFFBEB; min-height: 100vh; }
.empty { text-align: center; padding: 80rpx; color: #999; font-size: 28rpx; }
.count-bar { color: #92400E; font-size: 26rpx; margin-bottom: 16rpx; }
.card { background: #fff; border-radius: 16rpx; padding: 28rpx; margin-bottom: 20rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06); }
.stem { font-size: 30rpx; color: #1a1a1a; line-height: 1.5; }
.row { display: flex; justify-content: space-between; margin-top: 16rpx; }
.meta { align-items: center; }
.wrong-count { font-size: 24rpx; color: #ef4444; }
.last-time { font-size: 22rpx; color: #999; }

.modal-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 100; display: flex; align-items: center; justify-content: center; }
.modal { background: #fff; border-radius: 24rpx; padding: 40rpx; margin: 40rpx; max-height: 80vh; overflow-y: auto; }
.modal-stem { font-size: 32rpx; color: #1a1a1a; line-height: 1.6; margin-bottom: 24rpx; font-weight: 600; }
.options { margin-bottom: 24rpx; }
.opt { font-size: 28rpx; color: #333; padding: 8rpx 0; }
.opt-label { font-weight: 600; color: #B45309; }
.answer-block { background: #FEF3C7; border-radius: 12rpx; padding: 16rpx 20rpx; margin-bottom: 16rpx; }
.answer-label { font-size: 26rpx; color: #92400E; }
.answer-val { font-size: 28rpx; color: #B45309; font-weight: 700; }
.explanation { font-size: 26rpx; color: #666; line-height: 1.6; margin-bottom: 24rpx; }
.btn-clear { background: #B45309; color: #fff; border-radius: 12rpx; font-size: 28rpx; margin-bottom: 16rpx; }
.btn-cancel { background: #f3f4f6; color: #666; border-radius: 12rpx; font-size: 28rpx; }
