.page { padding: 24rpx; }
.card { margin-bottom: 24rpx; }

/* 状态栏 */
.stats { padding: 32rpx; }
.lv-circle {
  width: 96rpx; height: 96rpx; border-radius: 50%;
  background: linear-gradient(135deg, #FCD34D, #F59E0B);
  color: #fff; font-size: 32rpx; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
}
.lv-name { font-size: 28rpx; font-weight: 600; color: #333; }
.xp-bar { flex: 1; height: 14rpx; background: #FEF3C7; border-radius: 999rpx; overflow: hidden; }
.xp-fill { height: 100%; background: linear-gradient(90deg, #FCD34D, #F59E0B); }
.xp-text { font-size: 20rpx; color: #B45309; font-weight: 600; }

.stat-row { gap: 16rpx; margin-top: 24rpx; }
.stat-cell {
  flex: 1; border-radius: 16rpx; padding: 16rpx 0; text-align: center;
}
.stat-cell.warm  { background: #FFF5E6; }
.stat-cell.sage  { background: #F0F4EE; }
.stat-cell.honey { background: #FEF3C7; }
.stat-cell .emoji { font-size: 36rpx; }
.stat-cell .txt { font-size: 22rpx; font-weight: 600; margin-top: 4rpx; }
.stat-cell.warm  .txt { color: #B45309; }
.stat-cell.sage  .txt { color: #52624A; }
.stat-cell.honey .txt { color: #B45309; }

/* 今日小单元大 CTA */
.cta-lesson {
  padding: 36rpx 40rpx;
  background: linear-gradient(135deg, #FCD34D, #F59E0B);
  display: flex; align-items: center; justify-content: space-between;
}
.cta-lesson-inner { display: flex; align-items: center; gap: 24rpx; }
.cta-lesson-icon { font-size: 72rpx; }
.cta-lesson-title { font-size: 34rpx; font-weight: 700; color: #fff; }
.cta-lesson-sub { font-size: 22rpx; color: rgba(255,255,255,0.85); margin-top: 6rpx; }
.cta-lesson-arrow { font-size: 48rpx; color: rgba(255,255,255,0.8); font-weight: 300; }

/* 拍卷小 CTA */
.cta-shoot { padding: 24rpx 32rpx; background: #FFFBEB; }
.shoot-title { font-size: 26rpx; font-weight: 600; color: #B45309; }
.shoot-sub { font-size: 20rpx; color: #7A4F0A; margin-top: 4rpx; }
.shoot-arrow { font-size: 40rpx; color: #D97706; font-weight: 300; }

/* 弱点 */
.section-head {
  font-size: 26rpx; font-weight: 600; color: #52624A;
  justify-content: space-between; margin-bottom: 16rpx;
}
.section-head .hint { font-size: 20rpx; color: #999; font-weight: 400; }
.weak-row {
  display: flex; align-items: center; gap: 16rpx;
  background: #FAF7F2; border-radius: 16rpx;
  padding: 16rpx; margin-top: 12rpx;
}
.weak-row.recent { background: #FFF1F2; }
.weak-num {
  width: 44rpx; height: 44rpx; border-radius: 50%;
  background: #A8B89E; color: #fff;
  display: flex; align-items: center; justify-content: center;
  font-size: 22rpx; font-weight: 700; flex-shrink: 0;
}
.weak-row.recent .weak-num { background: #fb7185; }
.weak-tag { font-size: 24rpx; font-weight: 600; color: #333; }
.weak-cnt { font-size: 20rpx; color: #888; margin-top: 4rpx; }

/* 曲线 */
.chart-wrap {
  display: flex; align-items: flex-end; justify-content: space-around;
  height: 200rpx; padding: 16rpx 0;
}
.chart-bar {
  width: 56rpx; background: linear-gradient(180deg, #FCD34D, #F59E0B);
  border-radius: 12rpx 12rpx 0 0;
  position: relative; min-height: 30rpx;
}
.bar-val {
  position: absolute; top: -32rpx; left: 50%; transform: translateX(-50%);
  font-size: 20rpx; font-weight: 700; color: #B45309;
}
.chart-x { display: flex; justify-content: space-around; padding-top: 8rpx; }
.chart-x text { font-size: 18rpx; color: #999; }
