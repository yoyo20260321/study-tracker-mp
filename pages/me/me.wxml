<view class="page">
  <view class="card profile">
    <view class="row" style="gap: 24rpx;">
      <view class="avatar">👦</view>
      <view class="flex-1">
        <view class="name">{{user.phone || '未登录'}}</view>
        <view class="sub">{{user.created_at ? '注册于 ' + createdText : ''}}</view>
        <view class="lv-tag">Lv.{{stats.level}} · {{stats.level_name}}</view>
      </view>
    </view>
    <view class="row" style="gap: 12rpx; margin-top: 24rpx;">
      <view class="xp-bar"><view class="xp-fill" style="width: {{stats.xp_pct}}%;"></view></view>
      <text class="xp-text">⚡ {{stats.xp}}/{{stats.xp_max}}</text>
    </view>
  </view>

  <!-- 学情档案 -->
  <view class="card profile-card" bindtap="goProfile">
    <view class="row" style="justify-content: space-between; align-items: center;">
      <text class="pc-title">📚 学情档案</text>
      <text class="pc-edit">编辑 ›</text>
    </view>
    <view wx:if="{{user.profile_complete}}" class="pc-fields">
      <view class="pc-row"><text class="pc-k">年级</text><text class="pc-v">{{user.grade}}</text></view>
      <view class="pc-row"><text class="pc-k">科目</text><text class="pc-v">{{user.subject}}</text></view>
      <view class="pc-row"><text class="pc-k">城市</text><text class="pc-v">{{user.city}}</text></view>
      <view class="pc-row" wx:if="{{user.school}}"><text class="pc-k">学校</text><text class="pc-v">{{user.school}}</text></view>
    </view>
    <view wx:else class="pc-incomplete">
      <text>⚠️ 资料未完善, 点这里填好享受全市学情对标</text>
    </view>
  </view>

  <view class="grid3">
    <view class="cell"><view class="big">{{reportCount}}</view><view class="sm">累计诊断</view></view>
    <view class="cell"><view class="big" style="color:#fb7185;">{{stats.streak_current}} 🔥</view><view class="sm">连击天数</view></view>
    <view class="cell"><view class="big" style="color:#7A8C70;">Lv.{{stats.level}}</view><view class="sm">当前等级</view></view>
  </view>

  <!-- P4: 邀请卡片 -->
  <view class="card invite" bindtap="onInvite">
    <view class="row" style="justify-content: space-between; align-items: center;">
      <view>
        <view class="p-title">🎁 邀请好友, 一起冲连击</view>
        <view class="p-sub">已邀请 {{referral.count}} 人 · 累计 +{{referral.total_xp_earned}} XP</view>
      </view>
      <view class="p-btn">邀请</view>
    </view>
  </view>

  <!-- 我的成长 -->
  <view class="card growth">
    <view class="growth-title">🏅 我的成长</view>
    <view class="growth-row" bindtap="showBadges">
      <text class="gr-icon">🏅</text>
      <text class="gr-name flex-1">我的徽章</text>
      <text class="gr-sub">已得 {{badgeCount}}/8</text>
      <text class="gr-arr">›</text>
    </view>
    <view class="growth-row" bindtap="goWrongQuest">
      <text class="gr-icon">📝</text>
      <text class="gr-name flex-1">错题本</text>
      <text class="gr-sub">{{wrongCount}} 道待复习</text>
      <text class="gr-arr">›</text>
    </view>
    <view class="growth-row" bindtap="goLeaderboard">
      <text class="gr-icon">🏆</text>
      <text class="gr-name flex-1">全市排行</text>
      <text class="gr-arr">›</text>
    </view>
  </view>

  <!-- 徽章弹窗 -->
  <view wx:if="{{showBadgeModal}}" class="modal-mask" catchtap="closeBadges">
    <view class="modal" catchtap="">
      <view class="modal-title">🏅 我的徽章</view>
      <view class="badge-grid">
        <view wx:for="{{allBadges}}" wx:key="type" class="badge-cell {{item.earned ? 'earned' : 'locked'}}">
          <text class="badge-icon">{{item.icon}}</text>
          <text class="badge-name">{{item.name}}</text>
          <text class="badge-desc">{{item.desc}}</text>
        </view>
      </view>
      <button class="btn-close" bindtap="closeBadges">关闭</button>
    </view>
  </view>

  <view class="card promo" bindtap="goPay">
    <view class="row" style="justify-content: space-between; align-items: center;">
      <view>
        <view class="p-title">💰 蜂学会员·限时优惠</view>
        <view class="p-sub">月卡 ¥39 不限次 · 立减 ¥30</view>
      </view>
      <view class="p-btn">立即开通</view>
    </view>
  </view>

  <view class="card menu">
    <view class="row mrow" wx:for="{{menus}}" wx:key="name" bindtap="onMenu" data-key="{{item.key}}">
      <view class="m-icon">{{item.icon}}</view>
      <view class="m-name flex-1">{{item.name}}</view>
      <view class="m-sub" wx:if="{{item.sub}}">{{item.sub}}</view>
      <view class="m-arr">›</view>
    </view>
  </view>

  <view style="height: 32rpx;"></view>
  <button class="btn-logout" bindtap="logout">退出登录</button>
</view>
