.page { padding: 24rpx; }
.profile {
  padding: 40rpx; background: linear-gradient(135deg, #FEF3C7, #FFFBEB);
}
.avatar {
  width: 120rpx; height: 120rpx; border-radius: 50%;
  background: linear-gradient(135deg, #FCD34D, #F59E0B);
  display: flex; align-items: center; justify-content: center;
  font-size: 64rpx; color: #fff;
}
.name { font-size: 32rpx; font-weight: 700; color: #333; }
.sub { font-size: 22rpx; color: #888; margin-top: 6rpx; }
.lv-tag {
  display: inline-block; background: linear-gradient(135deg, #FCD34D, #F59E0B);
  color: #fff; border-radius: 999rpx; padding: 4rpx 16rpx;
  font-size: 20rpx; font-weight: 600; margin-top: 12rpx;
}
.xp-bar { flex: 1; height: 16rpx; background: #fff; border-radius: 999rpx; overflow: hidden; }
.xp-fill { height: 100%; background: linear-gradient(90deg, #FCD34D, #F59E0B); }
.xp-text { font-size: 20rpx; color: #B45309; font-weight: 600; }

.grid3 {
  display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16rpx; margin-top: 24rpx;
}
.cell {
  background: #fff; border-radius: 16rpx; padding: 24rpx 12rpx; text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(180,135,30,.05);
}
.big { font-size: 36rpx; font-weight: 700; color: #F59E0B; }
.sm { font-size: 20rpx; color: #888; margin-top: 6rpx; }

.promo {
  padding: 32rpx; margin-top: 24rpx;
  background: linear-gradient(135deg, #F59E0B, #B45309); color: #fff;
}
.p-title { font-size: 28rpx; font-weight: 700; }
.p-sub { font-size: 22rpx; opacity: .9; margin-top: 8rpx; }
.p-btn {
  background: #fff; color: #B45309; border-radius: 999rpx;
  padding: 12rpx 28rpx; font-size: 24rpx; font-weight: 600;
}

.menu { margin-top: 24rpx; padding: 0; }
.mrow { padding: 24rpx 32rpx; border-bottom: 1rpx solid #F0EBE0; }
.mrow:last-child { border-bottom: none; }
.m-icon { font-size: 36rpx; margin-right: 20rpx; }
.m-name { font-size: 26rpx; color: #333; }
.m-sub { font-size: 22rpx; color: #888; margin-right: 12rpx; }
.m-arr { color: #ccc; font-size: 32rpx; }

.profile-card { margin-top: 24rpx; padding: 24rpx 32rpx; }
.pc-title { font-size: 28rpx; font-weight: 600; color: #333; }
.pc-edit { font-size: 22rpx; color: #F59E0B; }
.pc-fields { margin-top: 16rpx; }
.pc-row { display: flex; padding: 10rpx 0; border-bottom: 1rpx solid #F5F0E5; }
.pc-row:last-child { border-bottom: none; }
.pc-k { font-size: 24rpx; color: #888; min-width: 100rpx; }
.pc-v { font-size: 26rpx; color: #333; flex: 1; }
.pc-incomplete {
  margin-top: 16rpx; padding: 16rpx; background: #FFF1F2; color: #fb7185;
  font-size: 22rpx; border-radius: 12rpx; text-align: center;
}

.btn-logout {
  background: #FAF7F2; color: #888; border: none;
  padding: 24rpx; border-radius: 16rpx; font-size: 26rpx;
  width: 100%; margin-top: 16rpx;
}
