<view class="page">
  <view class="card" wx:if="{{list.length === 0 && !loading}}">
    <view class="empty">
      <view class="bee-bob" style="font-size: 80rpx;">🐝</view>
      <view style="font-size: 26rpx; color: #888; margin-top: 16rpx;">还没有诊断记录</view>
      <button class="btn-primary" style="margin-top: 24rpx;" bindtap="goShoot">📸 去新诊断</button>
    </view>
  </view>

  <block wx:for="{{list}}" wx:key="id">
    <view class="card item" bindtap="goReport" data-id="{{item.id}}">
      <view class="score-circle">{{item.score}}</view>
      <view class="grow">
        <view class="t1">{{item.unit}}</view>
        <view class="t2">{{item.dateText}}</view>
      </view>
      <view class="stars-mini">
        <text wx:for="{{[1,2,3,4,5]}}" wx:key="*this" wx:for-item="s" class="{{s <= item.stars ? '' : 'dim'}}">⭐</text>
      </view>
    </view>
  </block>
</view>
